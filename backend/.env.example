# LLM - NVIDIA NIM (build.nvidia.com), used only by the GitHub agent
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# LLM - Mistral (console.mistral.ai), used by orchestrator/notion/jira/slack
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# Notion - internal integration secret (https://www.notion.so/profile/integrations)
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=

# GitHub - personal access token with repo scope
GITHUB_PERSONAL_ACCESS_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# Jira - API token (https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_URL=https://your-domain.atlassian.net
JIRA_USERNAME=you@example.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# Slack - bot token with chat:write scope
SLACK_BOT_TOKEN=xoxb-
SLACK_TEAM_ID=
SLACK_CHANNEL_ID=
